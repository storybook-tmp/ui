{
  "name": "evergreen-ui",
  "repository": "https://github.com/evergreen-ci/ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "check-types": "pnpm -r check-types",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "codegen": "pnpm -r codegen",
    "eslint:strict": "pnpm -r eslint:strict",
    "eslint:fix": "pnpm -r eslint:fix",
    "prepare": "husky",
    "storybook": "pnpm --filter spruce --filter parsley --filter @evg-ui/* --parallel run storybook --no-open & sleep 5 && storybook dev",
    "test": "vitest --typecheck=false"
  },
  "devDependencies": {
    "@evg-ui/storybook-addon": "workspace:*",
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.3",
    "vitest": "^3.2.4"
  }
}
